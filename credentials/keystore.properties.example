# Local release signing for Android — COPY this to `credentials/keystore.properties`
# and fill in your real values. The real file (and the .keystore) are git-ignored and
# must NEVER be committed. See docs/BUILD.md → "Release hardening".
#
# Generate the keystore (one-time), from the repo root:
#
#   keytool -genkeypair -v \
#     -keystore credentials/upload.keystore \
#     -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# `storeFile` is resolved relative to the `credentials/` directory.

storeFile=upload.keystore
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
